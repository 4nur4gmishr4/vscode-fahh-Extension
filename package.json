                    "config.fahh.sounds.task": "Task Failure Sound",
                    "config.fahh.sounds.shell": "Shell Command Failure Sound",
                    "config.fahh.sounds.terminal": "Terminal Failure Sound",
                    "config.fahh.sounds.diagnostics": "Diagnostic Error Sound",
                    "config.fahh.sounds.build": "Build Failure Sound",
                    "config.fahh.sounds.longTask": "Long Task Failure Sound",
                    "config.fahh.successEnabled": "Enable Success Sounds",
                    "config.fahh.successSound": "Success Sound File",
                    "config.fahh.volumes.task": "Task Volume (-1 = global)",
                    "config.fahh.volumes.shell": "Shell Volume (-1 = global)",
                    "config.fahh.volumes.terminal": "Terminal Volume (-1 = global)",
                    "config.fahh.volumes.diagnostics": "Diagnostics Volume (-1 = global)",
                    "config.fahh.volumes.build": "Build Volume (-1 = global)",
                    "config.fahh.volumes.longTask": "Long Task Volume (-1 = global)",
