                    "command.fahh.testSuccess": "Play Test Success Sound",
                    "command.fahh.toggle": "Toggle Enable / Disable",
                    "command.fahh.toggleWorkspace": "Toggle (This Workspace)",
                    "command.fahh.selectSound": "Select Custom Sound File...",
                    "command.fahh.selectSoundFolder": "Select Sound Folder (Random)",
                    "command.fahh.resetSound": "Reset Sound to Default",
                    "command.fahh.pickSoundPack": "Pick Sound Pack",
                    "command.fahh.stop": "Stop Currently Playing Sound",
                    "command.fahh.snooze": "Snooze for Configured Minutes",
                    "command.fahh.clearHistory": "Clear Failure History",
                    "command.fahh.replayLast": "Replay Last Failure Sound",
                    "command.fahh.showHistory": "Show Failure History",
                    "command.fahh.showOutput": "Show Output Log",
                    "command.fahh.resetSettings": "Reset Settings",
                    "command.fahh.factoryReset": "Factory Reset",
                    "command.fahh.showWelcome": "Show Welcome Screen",
                    "config.fahh.title": "Fahh",
                    "config.fahh.enabled": "Enable Fahh",
                    "config.fahh.soundPack": "Sound Pack",
